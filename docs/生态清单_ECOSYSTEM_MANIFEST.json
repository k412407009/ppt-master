{
  "schema_version": "1.0",
  "updated_at": "2026-04-22",
  "stack_name": "ppt-master-local-stack",
  "workspace_layout": {
    "type": "sibling_repos",
    "recommended_root": "~/Desktop/Git",
    "repos": [
      "ppt-master",
      "game-asset-collector",
      "game-review"
    ]
  },
  "shareable_entrypoints": {
    "team_onboarding_doc": "https://github.com/k412407009/ppt-master/blob/main/docs/%E5%90%8C%E4%BA%8B%E6%8E%A5%E5%85%A5%E6%8C%87%E5%8D%97_TEAM_ONBOARDING_GUIDE.md",
    "three_repo_stack_doc": "https://github.com/k412407009/ppt-master/blob/main/docs/%E4%B8%89%E4%BB%93%E5%8D%8F%E5%90%8C%E6%9E%B6%E6%9E%84_THREE_REPO_STACK.md",
    "repos": [
      "https://github.com/k412407009/ppt-master",
      "https://github.com/k412407009/game-asset-collector",
      "https://github.com/k412407009/game-review"
    ]
  },
  "configuration": {
    "required_runtime_split": {
      "ide_orchestration_model": "Managed by the user's IDE account, not by repo env vars.",
      "repo_env_vars": "Configured locally in .env or shell environment."
    },
    "recommended_env_vars": [
      {
        "name": "TAVILY_API_KEY",
        "used_by": [
          "game-asset-collector"
        ],
        "purpose": "Store-page extraction fallback and text capture"
      },
      {
        "name": "ARK_API_KEY",
        "used_by": [
          "game-asset-collector",
          "ppt-master"
        ],
        "purpose": "ARK / Doubao Vision labeling and Volcengine-compatible image features"
      },
      {
        "name": "VOLCENGINE_API_KEY",
        "used_by": [
          "game-asset-collector",
          "ppt-master"
        ],
        "purpose": "Alias for ARK-compatible Volcengine access; also used by image generation backends"
      },
      {
        "name": "COMPASS_API_KEY",
        "used_by": [
          "game-review"
        ],
        "purpose": "Primary review-model provider in the current public stack"
      },
      {
        "name": "IMAGE_BACKEND",
        "used_by": [
          "ppt-master"
        ],
        "purpose": "Selects the image generation provider such as volcengine, openai, or gemini"
      }
    ],
    "optional_internal_conventions": [
      {
        "name": "DEVTABLE_API_KEY",
        "status": "recommended_only",
        "notes": "DevTable is not currently a built-in dependency of the public three-repo stack."
      },
      {
        "name": "DEVTABLE_BASE_URL",
        "status": "recommended_only",
        "notes": "Suggested naming for a future internal collaboration-data layer."
      },
      {
        "name": "DEVTABLE_APP_ID",
        "status": "recommended_only",
        "notes": "Suggested naming for a future internal collaboration-data layer."
      },
      {
        "name": "DEVTABLE_TABLE_ID",
        "status": "recommended_only",
        "notes": "Suggested naming for a future internal collaboration-data layer."
      }
    ]
  },
  "modules": [
    {
      "id": "ppt-master",
      "role": "main_workflow",
      "repo_url": "https://github.com/k412407009/ppt-master",
      "local_dir": "ppt-master",
      "visibility": "public",
      "required": true,
      "entrypoints": [
        "README.md",
        "skills/ppt-master/SKILL.md",
        "skills/ppt-master/scripts/project_manager.py",
        "skills/ppt-master/scripts/image_gen.py"
      ],
      "depends_on": [
        "game-asset-collector"
      ],
      "optional_depends_on": [
        "game-review"
      ],
      "outputs": [
        "design_spec.md",
        "exports/*.pptx",
        "images/_game_assets_meta/*.image_resource_list.md"
      ]
    },
    {
      "id": "game-asset-collector",
      "role": "shared_asset_collection",
      "repo_url": "https://github.com/k412407009/game-asset-collector",
      "local_dir": "game-asset-collector",
      "visibility": "public",
      "required": true,
      "entrypoints": [
        "README.md",
        "scripts/fetch_game_assets.py",
        "game_asset_collector/fetch_game_assets.py"
      ],
      "depends_on": [],
      "optional_depends_on": [],
      "outputs": [
        "raw_assets/<game>/store/**",
        "raw_assets/<game>/gameplay/frames/**",
        "raw_assets/<game>/gameplay/labels.json",
        "raw_assets/<game>/gameplay/descriptions.json",
        "raw_assets/<game>/metadata.json"
      ]
    },
    {
      "id": "game-review",
      "role": "structured_review_reports",
      "repo_url": "https://github.com/k412407009/game-review",
      "local_dir": "game-review",
      "visibility": "public",
      "required": true,
      "entrypoints": [
        "README.md",
        "skills/game-review/SKILL.md",
        "game_review/cli.py"
      ],
      "depends_on": [
        "game-asset-collector"
      ],
      "optional_depends_on": [
        "ppt-master"
      ],
      "outputs": [
        "review/*_review.docx",
        "review/*_review.xlsx",
        "review/*_subjective_responses.md"
      ]
    }
  ],
  "model_and_api_layers": [
    {
      "layer": "orchestration",
      "type": "ide_agent_model",
      "providers": [
        "Claude",
        "ChatGPT/Codex",
        "other coding IDE models"
      ],
      "notes": "Reads SKILL docs and decides which scripts to run."
    },
    {
      "layer": "source_ingestion",
      "type": "deterministic_tools",
      "providers": [
        "curl_cffi",
        "requests",
        "pandoc",
        "Node fallback"
      ],
      "notes": "Used by ppt-master for source-to-Markdown conversion."
    },
    {
      "layer": "image_generation",
      "type": "direct_model_api",
      "providers": [
        "Gemini",
        "OpenAI",
        "Qwen",
        "Zhipu",
        "Volcengine",
        "Stability",
        "BFL",
        "Ideogram",
        "MiniMax",
        "SiliconFlow",
        "fal",
        "Replicate"
      ],
      "notes": "Configured through IMAGE_BACKEND in ppt-master."
    },
    {
      "layer": "asset_collection",
      "type": "api_and_media_tools",
      "providers": [
        "App Store API",
        "google_play_scraper",
        "Steam API",
        "Tavily",
        "yt-dlp",
        "ffmpeg",
        "ARK / Volcengine Vision"
      ],
      "notes": "Implemented in game-asset-collector."
    },
    {
      "layer": "review_generation",
      "type": "review_llm_provider",
      "providers": [
        "Compass",
        "future Volcengine-compatible provider",
        "future OpenAI-compatible provider"
      ],
      "notes": "Currently Compass first, local stub fallback."
    }
  ],
  "recommended_flows": [
    {
      "id": "ppt_only",
      "requires": [
        "ppt-master"
      ],
      "steps": [
        "Convert source materials to Markdown",
        "Generate design spec and SVG pages",
        "Export native PPTX"
      ]
    },
    {
      "id": "ppt_plus_assets",
      "requires": [
        "ppt-master",
        "game-asset-collector"
      ],
      "steps": [
        "Collect store screenshots and gameplay frames",
        "Generate image resource list",
        "Use collected assets in PPT"
      ]
    },
    {
      "id": "full_review_loop",
      "requires": [
        "ppt-master",
        "game-asset-collector",
        "game-review"
      ],
      "steps": [
        "Collect assets",
        "Prepare review.json",
        "Generate review reports",
        "Feed review outputs back into PPT if needed"
      ]
    }
  ]
}
